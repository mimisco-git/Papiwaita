[Icon Theme]
Name=Papiwaita
Comment=Papirus app icons with Adwaita symbolic system icons
Inherits=Papirus-Dark,Adwaita
Directories=16x16/apps,22x22/apps,24x24/apps,32x32/apps,48x48/apps,64x64/apps,symbolic/status,symbolic/devices,symbolic/actions

[16x16/apps]
Size=16
Type=Fixed

[22x22/apps]
Size=22
Type=Fixed

[24x24/apps]
Size=24
Type=Fixed

[32x32/apps]
Size=32
Type=Fixed

[48x48/apps]
Size=48
Type=Fixed

[64x64/apps]
Size=64
Type=Fixed

[symbolic/status]
Size=16
MinSize=16
MaxSize=512
Type=Scalable
Context=Status

[symbolic/devices]
Size=16
MinSize=16
MaxSize=512
Type=Scalable
Context=Devices

[symbolic/actions]
Size=16
MinSize=16
MaxSize=512
Type=Scalable
Context=Actions
